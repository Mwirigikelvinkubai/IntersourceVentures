# ─────────────────────────────────────────────────────────────
#  INTERSOURCE VENTURES – M-Pesa Daraja API Configuration
# ─────────────────────────────────────────────────────────────
#
#  STEP 1 – SANDBOX (for localhost development & testing)
#  --------------------------------------------------------
#  These are the official Safaricom sandbox test credentials.
#  They work right now with no sign-up needed.
#  Use the sandbox Paybill: 174379 for testing.
#
#  STEP 2 – GO LIVE (when ready for real payments)
#  ------------------------------------------------
#  1. Go to https://developer.safaricom.co.ke
#  2. Create an account and log in
#  3. Click "My Apps" → "Add New App"
#  4. Enable "Lipa Na M-Pesa" (STK Push)
#  5. Replace the values below with your LIVE credentials
#  6. Change MPESA_ENV=production
#  7. Change SHORTCODE and PASSKEY to your actual Paybill 400200 values
#
# ─────────────────────────────────────────────────────────────

# "sandbox" for testing | "production" for real payments
MPESA_ENV=sandbox

# --- SANDBOX credentials (use these to test now) ---
CONSUMER_KEY=GvzJCcW8EzMCZMEFAGEHIMsGqFxmCTge
CONSUMER_SECRET=SpUSBMZneCaIslDH

# --- LIVE credentials (fill in after going live on Daraja portal) ---
# CONSUMER_KEY=your_live_consumer_key_here
# CONSUMER_SECRET=your_live_consumer_secret_here

# Sandbox test shortcode (Paybill)
SHORTCODE=174379

# Sandbox passkey (official Safaricom sandbox passkey)
PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# --- LIVE shortcode & passkey (fill in after going live) ---
# SHORTCODE=400200
# PASSKEY=your_live_passkey_from_daraja_portal

# Your Intersource account number (used in STK prompt description)
ACCOUNT_REF=37996
TRANSACTION_DESC=Intersource Ventures Order

# Callback URL – where Safaricom sends payment confirmation
# For localhost we use ngrok. See README for setup instructions.
# Replace this with your ngrok URL each time you start a tunnel.
CALLBACK_URL=https://YOUR_NGROK_URL.ngrok-free.app/api/mpesa/callback

# Server port
PORT=3000
